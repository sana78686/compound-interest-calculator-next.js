# ─── Production / live (Plesk or VPS) ─────────────────────────────────────
# Copy this file to .env.production in the app folder next to package.json,
# OR paste each line into Plesk → Node.js → Custom environment variables.
#
# After changing env: rebuild (npm run build) if NEXT_PUBLIC_* changed, then restart Node.

NODE_ENV=production

# Laravel CMS base URL (no trailing slash)
NEXT_PUBLIC_CMS_API_URL=https://app.apimstec.com

# Public site hostname only (must match tenant in GlobalCMS)
NEXT_PUBLIC_SITE_DOMAIN=compresspdf.id

# Full origin visitors use — MUST match your primary domain (https, no trailing slash).
# If the site is https://www.compresspdf.id use that; if https://compresspdf.id use that.
# Redirect the other host to this one in nginx/Plesk so only one canonical URL exists.
NEXT_PUBLIC_SITE_ORIGIN=https://www.compresspdf.id

# Optional: base path if the app is not at domain root (rare)
# NEXT_PUBLIC_BASE_PATH=/

# CMS API path style (default true on many hosts)
# NEXT_PUBLIC_CMS_API_DOMAIN_PATH=true
